# Server
PORT=3001

# DoorDash credentials
DOORDASH_EMAIL=your@email.com
DOORDASH_PASSWORD=yourpassword

# GrubHub credentials (also covers Seamless)
GRUBHUB_EMAIL=your@email.com
GRUBHUB_PASSWORD=yourpassword

# Uber Eats credentials
UBEREATS_EMAIL=your@email.com
UBEREATS_PASSWORD=yourpassword

# Scraper settings
HEADLESS=true
SCRAPE_TIMEOUT_MS=30000
MAX_RESULTS_PER_PLATFORM=10

# Default delivery address
DEFAULT_ADDRESS=86 Horsneck Point Rd, Oceanport NJ 07757
